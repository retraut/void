# Void cloud-init smoke test
#
# Runs the actual user_data generated by buildCloudInit() in a fresh
# ubuntu:24.04 container to verify the bash steps execute without
# errors up to the point where the script would download the void-agent
# binary. That download will fail (no real release yet) — we capture
# the log and check the intermediate state to confirm everything else
# (cloudflared install, config write, systemd unit) succeeded.
#
# Build + run:
#   cd worker
#   pnpm test            # writes test/output/user_data.sh
#   docker build -f test/Dockerfile -t void-bootstrap-test .
#   docker run --rm void-bootstrap-test

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# cloudflared + curl need ca-certificates. systemd is also installed
# so the script's `systemctl daemon-reload` / `enable --now` steps
# actually run (in a real VM these are needed; in the test they
# silently no-op because we don't run an init).
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      curl ca-certificates systemd iproute2 \
 && rm -rf /var/lib/apt/lists/*

# Copy the extracted user_data. Path is relative to the build context
# (the worker/ directory), so we run `docker build` from there.
COPY test/output/user_data.sh /tmp/user_data.sh
RUN chmod +x /tmp/user_data.sh

# Run the bootstrap. We expect it to fail at the agent download
# (`curl: HTTP Error 404`) because there's no real release published
# yet. The `|| true` lets the rest of the Dockerfile (state check)
# run anyway. The log captures everything that did succeed.
RUN /tmp/user_data.sh > /var/log/void-bootstrap.log 2>&1 \
 || echo "(bootstrap exited non-zero — likely the void-agent release doesn't exist yet; see log)"

# Report the final state. Each `RUN` is a separate layer so the
# output stays readable.
RUN echo "=========================================" \
 && echo "  void cloud-init smoke test — final state" \
 && echo "=========================================" \
 && echo "" \
 && echo ">>> cloudflared binary:" \
 && (ls -la /usr/local/bin/cloudflared 2>&1 || echo "NOT INSTALLED") \
 && echo "" \
 && echo ">>> /etc/void/config.toml:" \
 && (cat /etc/void/config.toml 2>&1 || echo "NOT WRITTEN") \
 && echo "" \
 && echo ">>> /etc/systemd/system/void-agent.service:" \
 && (cat /etc/systemd/system/void-agent.service 2>&1 || echo "NOT CREATED") \
 && echo "" \
 && echo ">>> /var/log/void-bootstrap.log (last 40 lines):" \
 && tail -n 40 /var/log/void-bootstrap.log 2>&1 || echo "NO LOG"

# Default cmd: print the state from the layer above (cloudflared installed,
# config + systemd unit — wherever the script got to before agent 404).
CMD ["bash", "-c", "echo '>>> /var/log/void-bootstrap.log (full):' && cat /var/log/void-bootstrap.log 2>/dev/null || echo 'no log'"]
